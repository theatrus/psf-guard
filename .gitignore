# Tauri-generated artifacts (regenerated by `cargo tauri` build/packaging).
# tauri.macos.conf.json only ever holds machine-local OpenCV dylib paths
# injected by scripts/macos-opencv-dylibs.py, which now recreates it when absent.
/gen/schemas/*-schema.json
/gen/schemas/acl-manifests.json
/tauri.macos.conf.json

# Tauri externalBin sidecars for the Windows installer are built in CI
# (cargo build --bin psf-guard-cli, then copied here with the target-triple
# suffix) — never committed.
/binaries/
