# PSF Guard Configuration File
#
# This is an example configuration file for PSF Guard.
# Copy this file to psf-guard.toml and customize it for your setup.
# Command line arguments will override values in this config file.
#
# NOTE: This file holds only server-wide knobs (port, cache, pregeneration).
# The set of databases and their image directories is NOT configured here --
# it lives in the database registry (JSON), by default at
# <config>/psf-guard/config.json. Register a database with:
#   psf-guard server <db.sqlite> <image-dir>...
# or manage them from the web UI / Tauri app. See REJECT_ARCHIVE_PLAN.md and
# the "Multi-database support" section of CLAUDE.md for details.
#
# A legacy [database]/[images] section is still parsed for backward
# compatibility, but it is IGNORED in server mode -- do not add it here.

[server]
# Port to bind to (default: 3000)
port = 3000

# Host to bind to (default: "0.0.0.0")
host = "0.0.0.0"

# Enable CORS (default: true)
cors = true

# Optional notice shown below the application header on every page.
# Values are plain text. Set both link fields or omit both.
#
# [server.banner]
# title = "Demo site"
# message = "This public demo uses sample data. Changes may be reset."
# link_text = "Learn about PSF Guard"
# link_url = "https://psf-guard.com/"

[cache]
# Cache directory path (default: "./cache")
directory = "./cache"

# File cache TTL (default: "5m")
# Supports: 1s, 30s, 5m, 1h, 2h30m, 1d, etc.
file_ttl = "5m"

# Directory tree cache TTL (default: "5m")
# Supports: 1s, 30s, 5m, 1h, 2h30m, 1d, etc.
directory_ttl = "5m"

# Optional pregeneration configuration for background image processing
[pregeneration]
# Enable background pregeneration of images (default: false)
enabled = false

# Generate screen-sized previews (1200px max) when enabled (default: true)
screen = true

# Generate large previews (2000px max) when enabled (default: false) 
large = false

# Number of worker threads for pregeneration (default: number of CPU cores)
# workers = 4
